# Copy this file to .env.local and fill in real values.
# None of these are committed — .env* is in .gitignore.

# ─── Brevo (transactional email + contacts) ───
# Required. Get from Brevo → SMTP & API → API Keys.
BREVO_API_KEY=
# Required. Must be a verified sender in Brevo.
BREVO_SENDER_EMAIL=sales@sixsigmasouthafrica.co.za
BREVO_SENDER_NAME=Six Sigma South Africa
# Required. The inbox that receives internal lead notifications.
BREVO_NOTIFY_TO=contact@2ko.co.za
# Optional. Brevo Contacts list ID to upsert leads into.
# If blank, the /api/contact route creates a new list called
# "Website Enquiries" on first run and logs the ID.
BREVO_LIST_ID=

# ─── Sigmafy (leads ingestion — optional) ───
# Once the Sigmafy leads endpoint exists, set these two to enable
# automatic lead forwarding. If left blank the /api/contact route
# silently skips the Sigmafy call.
SIGMAFY_API_URL=
SIGMAFY_API_KEY=

# ─── OpenAI (job-application classifier) ───
# Used by src/lib/job-filter.ts to adjudicate weak-keyword hits on the
# /api/contact form (JOB vs ENQUIRY). Without this, weak hits fail open
# and job applications with ambiguous wording will reach the sales inbox.
# Strong-keyword hits are still blocked regardless.
OPENAI_API_KEY=

# ─── Public site URL ───
# Used by sitemap.ts, robots.ts, canonical URLs, OG tags.
NEXT_PUBLIC_SITE_URL=https://sixsigmasouthafrica.co.za

# ─── Google Ads API (local scripts only — never used by Next runtime) ───
# Used by scripts/google-ads/*.ts. See scripts/google-ads/README.md for setup.
# All five must be set before running test-connection.ts and beyond.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optional. Only set if your Customer ID sits under a Manager (MCC) account.
# This is the MCC's 10-digit ID, dashes stripped.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
